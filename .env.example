AI_PROVIDER=glm
GLM_API_KEY=your_glm_api_key
GLM_MODEL=glm-5v-turbo
GLM_API_BASE=https://open.bigmodel.cn/api/paas/v4/chat/completions
GLM_OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_TIMEOUT_SECONDS=120
GLM_BATCH_INTERVAL_SECONDS=0.5

# Kimi vision recognition path. Set AI_PROVIDER=kimi to use it.
KIMI_API_KEY=your_kimi_or_moonshot_api_key
KIMI_MODEL=kimi-k2.6
KIMI_API_BASE=https://api.moonshot.cn/v1/chat/completions
KIMI_TIMEOUT_SECONDS=120
AI_TOKEN_WARN_TOTAL=0

YQS_DEERFLOW_MODE=agent
YQS_DEERFLOW_MODEL=glm-agent
YQS_DASHBOARD_TOKEN=

FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_RECEIVE_ID_TYPE=chat_id
FEISHU_RECEIVE_ID=your_chat_id
FEISHU_NOTIFY_ON_RECOGNITION=true

# Feishu Wiki knowledge base echo sync. The 回显 command mirrors processed files from case_materials/.
FEISHU_KNOWLEDGE_SPACE_NAME=YQS PPT 图片素材库
FEISHU_KNOWLEDGE_SPACE_ID=
FEISHU_KNOWLEDGE_ROOT_NODE_TOKEN=
FEISHU_KNOWLEDGE_PARENT_TYPE=wiki
FEISHU_KNOWLEDGE_FOLDER_OBJ_TYPE=docx
FEISHU_KNOWLEDGE_USER_ACCESS_TOKEN=
FEISHU_KNOWLEDGE_FORCE_UPLOAD=false

# Feishu Bitable input source. Leave empty to keep using only the legacy Feishu Bot/images_raw flow.
FEISHU_BITABLE_APP_TOKEN=
FEISHU_BITABLE_TABLE_ID=
FEISHU_BITABLE_VIEW_ID=
FEISHU_BITABLE_FORM_VIEW_ID=
FEISHU_BITABLE_FORM_URL=
FEISHU_WEB_BASE_URL=https://www.feishu.cn
FEISHU_BITABLE_FIELD_NAME=名字
FEISHU_BITABLE_FIELD_DESCRIPTION=描述
FEISHU_BITABLE_FIELD_PROJECT=项目
FEISHU_BITABLE_FIELD_FILE=文件
FEISHU_BITABLE_FIELD_SOURCE=来源
FEISHU_BITABLE_FIELD_SOURCE_SUBCATEGORY=来源二级分类
FEISHU_BITABLE_FIELD_COMMERCIAL=是否可商用
FEISHU_BITABLE_FIELD_USABLE=是否可商用
FEISHU_BITABLE_MAX_RECORDS=20000
FEISHU_BITABLE_WARN_RATIOS=0.5,0.75,0.9
YQS_BITABLE_BATCH_LIMIT=100
YQS_AI_TIMEOUT_SECONDS=120
